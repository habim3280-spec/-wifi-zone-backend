# Configuration de la base de données (A obtenir sur MongoDB Atlas)
MONGODB_URI=votre_lien_mongodb_atlas

# Secret pour la sécurité (Généré automatiquement sur Render, ou mettez une phrase longue ici)
JWT_SECRET=phrase_secrete_tres_longue_et_aleatoire_12345

# Configuration Serveur
PORT=3000

# Configuration MikroTik (A remplir avec les accès de votre routeur)
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=votre_mot_de_passe

# Configuration Paiement (Simulation Niger)
PAYMENT_MODE=test
